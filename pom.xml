    <modelVersion>4.0.0</modelVersion>

    <groupId>com.app</groupId>
    <artifactId>MyProjectApplication</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>

    <modules>
        <module>Back-End</module>
        <module>Front-End-Mesic</module>
